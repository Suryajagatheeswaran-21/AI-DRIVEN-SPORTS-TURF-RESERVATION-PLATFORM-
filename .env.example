# ==========================================================
# Google Gemini & GCP Configurations
# ==========================================================
# GEMINI_API_KEY: Required for Gemini AI API calls and semantic search embeddings.
# Configure this via your GCP Vertex AI or standard Google AI developer keys.
GEMINI_API_KEY="your-api-key-here"
VITE_GEMINI_API_KEY="your-client-api-key-here"

# GOOGLE_CLOUD_PROJECT: Required for Vertex AI API resources initialization
GOOGLE_CLOUD_PROJECT="your-gcp-project-id"

# GOOGLE_CLOUD_LOCATION: Vertex AI deployment region (default: us-central1)
GOOGLE_CLOUD_LOCATION="us-central1"

# GEMINI_MODEL: AI model variant used for chats (default: gemini-1.5-flash)
GEMINI_MODEL="gemini-1.5-flash"


# ==========================================================
# Database Connection Configurations
# ==========================================================
# SPRING_DATASOURCE_URL: URL mapping to PostgreSQL with pgvector
SPRING_DATASOURCE_URL="jdbc:postgresql://db:5432/turfbooking"

# SPRING_DATASOURCE_USERNAME: Administrative database login user
SPRING_DATASOURCE_USERNAME="postgres"

# SPRING_DATASOURCE_PASSWORD: Database authorization secret
SPRING_DATASOURCE_PASSWORD="postgres"

# SPRING_JPA_HIBERNATE_DDL_AUTO: Table generation behavior (use "none" in production)
SPRING_JPA_HIBERNATE_DDL_AUTO="none"

# SPRING_JPA_SHOW_SQL: Verbose logging for executed SQL actions (true / false)
SPRING_JPA_SHOW_SQL="true"


# ==========================================================
# JWT Token Encryption Configurations
# ==========================================================
# JWT_SECRET: Cryptographic seed used for signing JWT login tokens (minimum 256 bits hex/string)
JWT_SECRET="9a2b8c7d6e5f4g3h2i1j0k9l8m7n6o5p4q3r2s1t0u9v8w7x6y5z4a3b2c1d0e"

# JWT_EXPIRATION: Token life in milliseconds (e.g. 86400000 ms = 24 Hours)
JWT_EXPIRATION=86400000

# JWT_REFRESH_EXPIRATION: Refresh Token life in milliseconds (e.g. 604800000 ms = 7 Days)
JWT_REFRESH_EXPIRATION=604800000


# ==========================================================
# General Platform Configurations
# ==========================================================
# PORT: External mapped port representing entrypoint
PORT=8080

# APP_URL: The hosting address of this applet in production
APP_URL="http://localhost:3000"

